{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=esm --packages=external --sourcemap --outfile=dist/server.js",
    "start": "node dist/server.js",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "mnemonics:generate": "tsx scripts/batchMnemonics.ts",
    "mnemonics:generateHooks": "tsx scripts/generateHooks.ts",
    "mnemonics:fix": "tsx scripts/fixMnemonics.ts",
    "mnemonics:status": "tail -5 ~/batch_mnemonics.log"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@supabase/supabase-js": "^2.105.3",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-virtual": "^3.13.26",
    "@types/adm-zip": "^0.5.8",
    "@vitejs/plugin-react": "^5.0.4",
    "adm-zip": "^0.5.17",
    "autoprefixer": "^10.4.21",
    "axios": "^1.18.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "esbuild": "^0.28.0",
    "express": "^4.21.2",
    "hanzi-writer": "^3.7.3",
    "idb-keyval": "^6.2.5",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-icons": "^5.6.0",
    "swiper": "^12.1.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "eslint": "^10.3.0"
  }
}
